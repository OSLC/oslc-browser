# ============================================================
# Program
# ============================================================

<#ProgramShape>
  a sh:NodeShape ;
  sh:targetClass mrm:Program ;
  # Inherited from oslc_am:Resource / OSLC Core
  sh:property <#sp-title> ;
  sh:property <#sp-description> ;
  sh:property <#sp-identifier> ;
  sh:property <#sp-creator> ;
  sh:property <#sp-contributor> ;
  sh:property <#sp-created> ;
  sh:property <#sp-modified> ;
  sh:property <#sp-subject> ;
  sh:property <#sp-type> ;
  sh:property <#sp-instanceShape> ;
  sh:property <#sp-serviceProvider> ;
  sh:property <#sp-shortTitle> ;
  # Inherited from mrm:Element
  sh:property <#sp-fromDate> ;
  sh:property <#sp-toDate> ;
  sh:property <#sp-status> ;
  # Inherited from BudgetableItem
  sh:property <#sp-budget_1> ;
  sh:property <#sp-budget_2> ;
  sh:property <#sp-allocation_1> ;
  # Inherited from DeliverableElement
  sh:property <#sp-deliveredBy> ;
  # Inherited from AssessableElement
  sh:property <#sp-assessedBy> ;
  # Inherited from AccountableElement
  sh:property <#sp-accountableTo> ;
  # Inherited from ImpcatableElement
  sh:property <#sp-assessment> ;
  # Program-specific
  sh:property <#sp-needsCategory> ;
  sh:property <#sp-roleType> ;
  sh:property <#sp-programClass> ;
  sh:property <#sp-programType> ;
  sh:property <#sp-isFormalProgram> ;
  sh:property <#sp-programVision> ;
  sh:property <#sp-subPrograms> ;
  sh:property <#sp-administers> ;
  sh:property <#sp-contributesTo> .


