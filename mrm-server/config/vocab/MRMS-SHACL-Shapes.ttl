@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix oslc:    <http://open-services.net/ns/core#> .
@prefix oslc_am: <http://open-services.net/ns/am#> .
@prefix mrm:     <http://www.misa.org.ca/mrm#> .

# ================================================================
# SHACL Shapes for the MISA Municipal Reference Model (MRMS)
#
# Generated from OSLC ResourceShapes (MRMS-Shapes.ttl).
# mrm:Element rdfs:subClassOf oslc_am:Resource, so all MRMS
# resource shapes inherit the standard OSLC Core and AM properties.
#
# Property shapes are named nodes so that shared/inherited
# properties are defined once and referenced by multiple node shapes.
# ================================================================


# ================================================================
# SHARED PROPERTY SHAPES — Inherited from oslc_am:Resource
# ================================================================

<#sp-title>
  a sh:PropertyShape ;
  sh:path dcterms:title ;
  sh:name "title" ;
  sh:description "Title of the resource." ;
  sh:minCount 1 ;
  sh:maxCount 1 ;
  sh:datatype xsd:string .

<#sp-description>
  a sh:PropertyShape ;
  sh:path dcterms:description ;
  sh:name "description" ;
  sh:description "Descriptive text about the resource." ;
  sh:maxCount 1 ;
  sh:datatype xsd:string .

<#sp-identifier>
  a sh:PropertyShape ;
  sh:path dcterms:identifier ;
  sh:name "identifier" ;
  sh:description "Unique identifier of the resource." ;
  sh:maxCount 1 ;
  sh:datatype xsd:string .

<#sp-creator>
  a sh:PropertyShape ;
  sh:path dcterms:creator ;
  sh:name "creator" ;
  sh:description "Creator of the resource." ;
  sh:nodeKind sh:BlankNodeOrIRI .

<#sp-contributor>
  a sh:PropertyShape ;
  sh:path dcterms:contributor ;
  sh:name "contributor" ;
  sh:description "Contributor to the resource." .

<#sp-created>
  a sh:PropertyShape ;
  sh:path dcterms:created ;
  sh:name "created" ;
  sh:description "Date the resource was created." ;
  sh:maxCount 1 ;
  sh:datatype xsd:dateTime .

<#sp-modified>
  a sh:PropertyShape ;
  sh:path dcterms:modified ;
  sh:name "modified" ;
  sh:description "Date the resource was last modified." ;
  sh:maxCount 1 ;
  sh:datatype xsd:dateTime .

<#sp-subject>
  a sh:PropertyShape ;
  sh:path dcterms:subject ;
  sh:name "subject" ;
  sh:description "Tag or keyword for the resource." ;
  sh:datatype xsd:string .

<#sp-type>
  a sh:PropertyShape ;
  sh:path rdf:type ;
  sh:name "type" ;
  sh:description "RDF type of the resource." ;
  sh:nodeKind sh:IRI .

<#sp-instanceShape>
  a sh:PropertyShape ;
  sh:path oslc:instanceShape ;
  sh:name "instanceShape" ;
  sh:description "Resource shape that describes this resource." ;
  sh:maxCount 1 ;
  sh:nodeKind sh:IRI .

<#sp-serviceProvider>
  a sh:PropertyShape ;
  sh:path oslc:serviceProvider ;
  sh:name "serviceProvider" ;
  sh:description "OSLC service provider for this resource." ;
  sh:nodeKind sh:IRI .

<#sp-shortTitle>
  a sh:PropertyShape ;
  sh:path oslc:shortTitle ;
  sh:name "shortTitle" ;
  sh:description "Shorter form of the title." ;
  sh:maxCount 1 ;
  sh:datatype xsd:string .


# ================================================================
# SHARED PROPERTY SHAPES — Inherited from mrm:Element
# ================================================================

<#sp-fromDate>
  a sh:PropertyShape ;
  sh:path mrm:fromDate ;
  sh:name "fromDate" ;
  sh:description "Start date for the element." ;
  sh:maxCount 1 ;
  sh:datatype xsd:date .

<#sp-toDate>
  a sh:PropertyShape ;
  sh:path mrm:toDate ;
  sh:name "toDate" ;
  sh:description "End date for the element." ;
  sh:maxCount 1 ;
  sh:datatype xsd:date .

<#sp-status>
  a sh:PropertyShape ;
  sh:path mrm:status ;
  sh:name "status" ;
  sh:description "Current status of the element (Active, Inactive)." ;
  sh:maxCount 1 ;
  sh:nodeKind sh:IRI ;
  sh:class mrm:StatusType .


# ================================================================
# SHARED PROPERTY SHAPES — Inherited from Mixin Classes
# ================================================================

# --- BudgetableItem (Program, OrganizationUnit) ---

