# ============================================================
# Program
# Mixins: ImpcatableElement, BudgetableItem, DeliverableElement,
#         AssessableElement, Element, AccountableElement
# ============================================================

<#ProgramShape>
  a oslc:ResourceShape ;
  dcterms:title "Program" ;
  oslc:describes mrm:Program ;
  # Inherited from oslc_am:Resource / OSLC Core
  oslc:property <#p-title> ;
  oslc:property <#p-description> ;
  oslc:property <#p-identifier> ;
  oslc:property <#p-creator> ;
  oslc:property <#p-contributor> ;
  oslc:property <#p-created> ;
  oslc:property <#p-modified> ;
  oslc:property <#p-subject> ;
  oslc:property <#p-type> ;
  oslc:property <#p-instanceShape> ;
  oslc:property <#p-serviceProvider> ;
  oslc:property <#p-shortTitle> ;
  # Inherited from mrm:Element
  oslc:property <#p-fromDate> ;
  oslc:property <#p-toDate> ;
  oslc:property <#p-status> ;
  # Inherited from BudgetableItem
  oslc:property <#p-budget_1> ;
  oslc:property <#p-budget_2> ;
  oslc:property <#p-allocation_1> ;
  # Inherited from DeliverableElement
  oslc:property <#p-deliveredBy> ;
  # Inherited from AssessableElement
  oslc:property <#p-assessedBy> ;
  # Inherited from AccountableElement
  oslc:property <#p-accountableTo> ;
  # Inherited from ImpcatableElement
  oslc:property <#p-assessment> ;
  # Program-specific
  oslc:property <#p-needsCategory> ;
  oslc:property <#p-roleType> ;
  oslc:property <#p-programClass> ;
  oslc:property <#p-programType> ;
  oslc:property <#p-isFormalProgram> ;
  oslc:property <#p-programVision> ;
  oslc:property <#p-subPrograms> ;
  oslc:property <#p-administers> ;
  oslc:property <#p-contributesTo> .


