  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:range mrm:NeedsCategory .

<#p-roleType>
  a oslc:Property ;
  oslc:name "roleType" ;
  oslc:propertyDefinition mrm:roleType ;
