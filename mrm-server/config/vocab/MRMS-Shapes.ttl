@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix oslc:    <http://open-services.net/ns/core#> .
@prefix oslc_am: <http://open-services.net/ns/am#> .
@prefix mrm:     <http://www.misa.org.ca/mrm#> .

# ================================================================
# OSLC Resource Shapes for the MISA Municipal Reference Model (MRMS)
#
# mrm:Element rdfs:subClassOf oslc_am:Resource, so all MRMS
# resource shapes inherit the standard OSLC Core and AM properties.
#
# Property definitions are named nodes so that shared/inherited
# properties are defined once and referenced by multiple shapes.
# ================================================================


# ================================================================
# SHARED PROPERTY DEFINITIONS — Inherited from oslc_am:Resource
# ================================================================

<#p-title>
  a oslc:Property ;
  oslc:name "title" ;
  oslc:propertyDefinition dcterms:title ;
  dcterms:description "Title of the resource." ;
  oslc:occurs oslc:Exactly-one ;
  oslc:valueType xsd:string .

<#p-description>
  a oslc:Property ;
  oslc:name "description" ;
  oslc:propertyDefinition dcterms:description ;
  dcterms:description "Descriptive text about the resource." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:string .

<#p-identifier>
  a oslc:Property ;
  oslc:name "identifier" ;
  oslc:propertyDefinition dcterms:identifier ;
  dcterms:description "Unique identifier of the resource." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:string ;
  oslc:readOnly true .

<#p-creator>
  a oslc:Property ;
  oslc:name "creator" ;
  oslc:propertyDefinition dcterms:creator ;
  dcterms:description "Creator of the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:AnyResource ;
  oslc:representation oslc:Either .

<#p-contributor>
  a oslc:Property ;
  oslc:name "contributor" ;
  oslc:propertyDefinition dcterms:contributor ;
  dcterms:description "Contributor to the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:AnyResource ;
  oslc:representation oslc:Either .

<#p-created>
  a oslc:Property ;
  oslc:name "created" ;
  oslc:propertyDefinition dcterms:created ;
  dcterms:description "Date the resource was created." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:dateTime ;
  oslc:readOnly true .

<#p-modified>
  a oslc:Property ;
  oslc:name "modified" ;
  oslc:propertyDefinition dcterms:modified ;
  dcterms:description "Date the resource was last modified." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:dateTime ;
  oslc:readOnly true .

<#p-subject>
  a oslc:Property ;
  oslc:name "subject" ;
  oslc:propertyDefinition dcterms:subject ;
  dcterms:description "Tag or keyword for the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType xsd:string .

<#p-type>
  a oslc:Property ;
  oslc:name "type" ;
  oslc:propertyDefinition rdf:type ;
  dcterms:description "RDF type of the resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference .

<#p-instanceShape>
  a oslc:Property ;
  oslc:name "instanceShape" ;
  oslc:propertyDefinition oslc:instanceShape ;
  dcterms:description "Resource shape that describes this resource." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:readOnly true .

<#p-serviceProvider>
  a oslc:Property ;
  oslc:name "serviceProvider" ;
  oslc:propertyDefinition oslc:serviceProvider ;
  dcterms:description "OSLC service provider for this resource." ;
  oslc:occurs oslc:Zero-or-many ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:readOnly true .

<#p-shortTitle>
  a oslc:Property ;
  oslc:name "shortTitle" ;
  oslc:propertyDefinition oslc:shortTitle ;
  dcterms:description "Shorter form of the title." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:string .


# ================================================================
# SHARED PROPERTY DEFINITIONS — Inherited from mrm:Element
# ================================================================

<#p-fromDate>
  a oslc:Property ;
  oslc:name "fromDate" ;
  oslc:propertyDefinition mrm:fromDate ;
  dcterms:description "Start date for the element." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:date .

<#p-toDate>
  a oslc:Property ;
  oslc:name "toDate" ;
  oslc:propertyDefinition mrm:toDate ;
  dcterms:description "End date for the element." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:date .

<#p-status>
  a oslc:Property ;
  oslc:name "status" ;
  oslc:propertyDefinition mrm:status ;
  dcterms:description "Current status of the element (Active, Inactive)." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType oslc:Resource ;
  oslc:representation oslc:Reference ;
  oslc:range mrm:StatusType .


# ================================================================
# SHARED PROPERTY DEFINITIONS — Inherited from Mixin Classes
# ================================================================

# --- BudgetableItem (Program, OrganizationUnit) ---

<#p-budget_1>
  a oslc:Property ;
  oslc:name "budget_1" ;
  oslc:propertyDefinition mrm:budget_1 ;
  dcterms:description "Primary budget amount." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:float .

<#p-budget_2>
  a oslc:Property ;
  oslc:name "budget_2" ;
  oslc:propertyDefinition mrm:budget_2 ;
  dcterms:description "Secondary budget amount." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:float .

<#p-allocation_1>
  a oslc:Property ;
  oslc:name "allocation_1" ;
  oslc:propertyDefinition mrm:allocation_1 ;
  dcterms:description "Budget allocation amount." ;
  oslc:occurs oslc:Zero-or-one ;
  oslc:valueType xsd:float .

