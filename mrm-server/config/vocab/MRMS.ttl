@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<http://www.misa.org.ca/mrm>
  a owl:Ontology ;
  owl:imports <http://open-services.net/ns/am>, dc11: .

<http://www.misa.org.ca/mrm#ProcessImpacts>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "An assessment or measure of the impact a change driver has on a process."^^xsd:string .

<http://www.misa.org.ca/mrm#Element>
  a rdfs:Class ;
  dc11:description "The root superclass of all MRM elements"^^xsd:string ;
  rdfs:subClassOf <http://open-services.net/ns/am#Resource> .

<http://www.misa.org.ca/mrm#OrganizationUnit>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#AccountabilityElement>, <http://www.misa.org.ca/mrm#BudgetableItem>, <http://www.misa.org.ca/mrm#LocatableElement>, <http://www.misa.org.ca/mrm#Element>, <http://www.misa.org.ca/mrm#DeliverableElement> ;
  dc11:description "A point of authority, accountability or responsibility commanding resources commensurate with its obligations."^^xsd:string .

<http://www.misa.org.ca/mrm#AccountabilityElement>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Resource .

<http://www.misa.org.ca/mrm#BudgetableItem>
  a rdfs:Class ;
  dc11:description "An element that can have associated budget information."^^xsd:string .

<http://www.misa.org.ca/mrm#LocatableElement>
  a rdfs:Class ;
  dc11:description "An element that can have a location"^^xsd:string .

<http://www.misa.org.ca/mrm#DeliverableElement>
  a rdfs:Class ;
  dc11:description "An element that can be delivered by a project that changes the municipal business architecture in some way."^^xsd:string .

<http://www.misa.org.ca/mrm#Output>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "A unit of value produced by a Service and conveyed to a Service Recipient."^^xsd:string .

<http://www.misa.org.ca/mrm#ReportingRelationshipType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#PerformanceIndicatorType>
  a rdfs:Class ;
  dc11:description "A closed classification of Performance Indicators."^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#OutputProducer>
  a rdfs:Class ;
  dc11:description "An element that can produce an output (a service or process)."^^xsd:string .

<http://www.misa.org.ca/mrm#BusinessProcess>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Work performed from an external event to the completion of the organization's response to that external event that may involve municipal services and processes"^^xsd:string .

<http://www.misa.org.ca/mrm#AssessableElement>
  a rdfs:Class ;
  dc11:description "An element that can be assessed by performance indicators."^^xsd:string .

<http://www.misa.org.ca/mrm#ChangeDriver>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Something that is expected to cause material change to programs, services, processes or resources. Called an Influencer in BMM."^^xsd:string .

<http://www.misa.org.ca/mrm#AccountableElement>
  a rdfs:Class ;
  dc11:description "An element for which an organization unit can be held accountable."^^xsd:string .

<http://www.misa.org.ca/mrm#TargetGroupType>
  a rdfs:Class ;
  dc11:description "A closed classification of Target Groups.  There are three types of Target Groups: Individual, Group of Individuals, and Legal Entity.  "^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ImpactAssessment> a rdfs:Class .
<http://www.misa.org.ca/mrm#ProcessType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ResourceImpacts>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "An assessment or measure of the impact a change driver has on a resource."^^xsd:string .

<http://www.misa.org.ca/mrm#Process>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#ImpcatableElement>, <http://www.misa.org.ca/mrm#AccountableElement>, <http://www.misa.org.ca/mrm#Element>, <http://www.misa.org.ca/mrm#AssessableElement>, <http://www.misa.org.ca/mrm#OutputProducer>, <http://www.misa.org.ca/mrm#DeliverableElement> ;
  dc11:description "A business concept that deals with a sequence of tasks, executed by a role, using input resources to produce higher value outputs. Processes are triggered by events. Processes participate in a value chain to produce service outputs."^^xsd:string .

<http://www.misa.org.ca/mrm#ImpcatableElement>
  a rdfs:Class ;
  dc11:description "An element that can be impacted by a change driver."^^xsd:string .

<http://www.misa.org.ca/mrm#TargetGroup>
  a rdfs:Class ;
  dc11:description """A set of Parties that share intrinsic or extrinsic characteristics causing a Program to identify (target) them. A Population Segment with a Recognized Need. The set of legal entities defined by common extrinsic and/or intrinsic properties the government proposes to serve (meet needs) by policy. The most important notion is that the definition be independent of program or service context. Distinguish from:
1) outreach: the set of legal entities the government reaches/contacts with the intent to serve. The set may be smaller or larger than the target group. 

2) served: the set of legal entities the government actually serves. Most people call this set 'clients', and give them a name that reflects the service context. Sometimes known as 'client set'."""^^xsd:string ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> .

<http://www.misa.org.ca/mrm#Service>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#ImpcatableElement>, <http://www.misa.org.ca/mrm#OutputProducer>, <http://www.misa.org.ca/mrm#Element>, <http://www.misa.org.ca/mrm#AssessableElement>, <http://www.misa.org.ca/mrm#LocatableElement>, <http://www.misa.org.ca/mrm#AccountableElement>, <http://www.misa.org.ca/mrm#DeliverableElement> ;
  dc11:description "A commitment to deliver Outputs that have Service Value and contribute to Outcomes."^^xsd:string .

<http://www.misa.org.ca/mrm#StatusType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ServiceValue>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Defines the expectations of parties receiving the Service's Output directly or indirectly, and ensures their alignment with associated Service Objectives and Outcomes. The way in which delivering the Service Output to the Target Groups contributes to Program and Service Outcomes."^^xsd:string .

<http://www.misa.org.ca/mrm#ProgramType>
  a rdfs:Class ;
  dc11:description "A closed classification of Programs."^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ProjectType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#NeedsCategory>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype ;
  dc11:description "A closed classification of Programs and Services according to Recognized Needs.  "^^xsd:string .

<http://www.misa.org.ca/mrm#Need>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "A Need is defined as a condition wanting or requiring relief."^^xsd:string .

<http://www.misa.org.ca/mrm#Outcome>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element>, <http://www.misa.org.ca/mrm#AssessableElement> ;
  dc11:description "A desirable change in the level of a Target Group Need resulting from Service delivery."^^xsd:string .

<http://www.misa.org.ca/mrm#ProgramImpacts>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "An assessment or measure of the impact a change driver has on a program."^^xsd:string .

<http://www.misa.org.ca/mrm#Project>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Encapsulates discrete initiatives that an organization may approve to transform the business of the organization (e.g. business process re-engineering project), to develop assets (e.g. construction project), provide programs and services, etc. A collaborative initiative that is planned to achieve a particular aim."^^xsd:string .

<http://www.misa.org.ca/mrm#ChangeDriverType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#Program>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#ImpcatableElement>, <http://www.misa.org.ca/mrm#BudgetableItem>, <http://www.misa.org.ca/mrm#DeliverableElement>, <http://www.misa.org.ca/mrm#AssessableElement>, <http://www.misa.org.ca/mrm#Element>, <http://www.misa.org.ca/mrm#AccountableElement> ;
  dc11:description "A Program is a Mandate to achieve Outcomes by delivering Services. Organization Units are accountable for Programs that administer Services."^^xsd:string .

<http://www.misa.org.ca/mrm#OrganizationUnitType>
  a rdfs:Class ;
  dc11:description "An open classification of Organization Units. "^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ServiceOutputType>
  a rdfs:Class ;
  dc11:description "A closed classification of Service Outputs."^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ResourceAuthorities>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Specifies information about the resource authorized by an organization unit in terms of roles and budget allocations."^^xsd:string .

<http://www.misa.org.ca/mrm#ProcessResponsibilities>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Specifies information about the process responsibilities of an organization unit in terms of roles and budget allocations."^^xsd:string .

<http://www.misa.org.ca/mrm#ServiceAccountabilities>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Specifies information about the services an organization unit is accountable for in terms of roles and budget allocations."^^xsd:string .

<http://www.misa.org.ca/mrm#ServiceImpacts>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "An assessment or measure of the impact a change driver has on a service."^^xsd:string .

<http://www.misa.org.ca/mrm#Location>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "A business concept that defines a location of interest to the business where processes are carried out, resources are located and parties are located"^^xsd:string .

<http://www.misa.org.ca/mrm#OutputType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ServiceLevelAgreements>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "Information about the relationship that one Provider / Internal Service has with zero, one or more Public and/or other Provider / Internal Services."^^xsd:string .

<http://www.misa.org.ca/mrm#ResourceType>
  a rdfs:Class ;
  dc11:description "An open classification of Resources."^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#LocationType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#RoleType>
  a rdfs:Class ;
  dc11:description "A closed classification of roles organization units play in relationship to the other organizaiton units, programs, services, processes and resources."^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ProcesLevelType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#Resource>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#ImpcatableElement>, <http://www.misa.org.ca/mrm#DeliverableElement>, <http://www.misa.org.ca/mrm#Element>, <http://www.misa.org.ca/mrm#LocatableElement>, <http://www.misa.org.ca/mrm#AssessableElement>, <http://www.misa.org.ca/mrm#AccountableElement> ;
  dc11:description "A tangible or intangible asset used to perform or consumed by activities in a process."^^xsd:string .

<http://www.misa.org.ca/mrm#ServiceType>
  a rdfs:Class ;
  dc11:description "A closed classification of Service.  A Service is either a “public” service offered to clients, or an “internal” service offered within the municipality to other public or internal service providers."^^xsd:string ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#ProgramClassType>
  a rdfs:Class ;
  rdfs:subClassOf rdfs:Datatype .

<http://www.misa.org.ca/mrm#PerformanceIndicator>
  a rdfs:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrm#Element> ;
  dc11:description "A measure of the efficiency, effectiveness and quality of a Program, a Service, a Process, an Activity, a Task or a Resource."^^xsd:string .

<http://www.misa.org.ca/mrm#allocation>
  a rdf:Property ;
  rdfs:domain <http://www.misa.org.ca/mrm#Service> ;
  rdfs:range xsd:float .

