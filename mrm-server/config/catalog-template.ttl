    oslc:resourceType mrm:OrganizationUnit ;
    oslc:hintHeight "505px" ;
    oslc:hintWidth "680px" ;
    oslc:resourceShape <shapes/MRMS-Shapes#OrganizationUnitShape>
  ] ;
  oslc:creationDialog [
    a oslc:Dialog ;
