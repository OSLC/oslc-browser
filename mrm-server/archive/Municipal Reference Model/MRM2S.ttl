  rdfs:label "Process Responsibilities"^^xsd:string ;
  owl:disjointWith <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#ServiceAccountabilities> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#AccountabilityElement> ;
  dc11:description "Specifies information about the process responsibilities of an organization unit in terms of roles and budget allocations."^^xsd:string .

<http://www.misa.org.ca/mrms#Program>
  a owl:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#ImpcatableElement>, <http://www.misa.org.ca/mrms#AssessableElement>, <http://www.misa.org.ca/mrms#DeliverableElement>, <http://www.misa.org.ca/mrms#Element>, <http://www.misa.org.ca/mrms#BudgetableItem>, <http://www.misa.org.ca/mrms#AccountableElement> ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Service> ;
  dc11:description "A Program is a Mandate to achieve Outcomes by delivering Services. Organization Units are accountable for Programs that administer Services."^^xsd:string ;
  rdfs:label "Program"^^xsd:string .

<http://www.misa.org.ca/mrms#Resource>
  a owl:Class ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#LocatableElement>, <http://www.misa.org.ca/mrms#AssessableElement>, <http://www.misa.org.ca/mrms#Element>, <http://www.misa.org.ca/mrms#AccountableElement>, <http://www.misa.org.ca/mrms#DeliverableElement>, <http://www.misa.org.ca/mrms#ImpcatableElement> ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#OrganizationUnit> ;
  dc11:description "A tangible or intangible asset used to perform or consumed by activities in a process."^^xsd:string ;
  rdfs:label "Resource"^^xsd:string .

<http://www.misa.org.ca/mrms#OrganizationUnit>
  a owl:Class ;
  dc11:description "A point of authority, accountability or responsibility commanding resources commensurate with its obligations."^^xsd:string ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element>, <http://www.misa.org.ca/mrms#LocatableElement>, <http://www.misa.org.ca/mrms#BudgetableItem>, <http://www.misa.org.ca/mrms#DeliverableElement> ;
  owl:disjointWith <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Output> ;
  rdfs:label "Organization Unit"^^xsd:string .

<http://www.misa.org.ca/mrms#TargetGroup>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Location> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  dc11:description """A set of Parties that share intrinsic or extrinsic characteristics causing a Program to identify (target) them. A Population Segment with a Recognized Need. The set of legal entities defined by common extrinsic and/or intrinsic properties the government proposes to serve (meet needs) by policy. The most important notion is that the definition be independent of program or service context. Distinguish from:
1) outreach: the set of legal entities the government reaches/contacts with the intent to serve. The set may be smaller or larger than the target group. 

2) served: the set of legal entities the government actually serves. Most people call this set 'clients', and give them a name that reflects the service context. Sometimes known as 'client set'."""^^xsd:string ;
  rdfs:label "Target Group"^^xsd:string .

<http://www.misa.org.ca/mrms#Outcome>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#OrganizationUnit> ;
  dc11:description "A desirable change in the level of a Target Group Need resulting from Service delivery."^^xsd:string ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  rdfs:label "Outcome"^^xsd:string .

<http://www.misa.org.ca/mrms#Need>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#PerformanceIndicator> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  dc11:description "A Need is defined as a condition wanting or requiring relief."^^xsd:string ;
  rdfs:label "Need"^^xsd:string .

<http://www.misa.org.ca/mrms#ChangeDriver>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#ProcessResponsibilities> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  dc11:description "Something that is expected to cause material change to programs, services, processes or resources. Called an Influencer in BMM."^^xsd:string ;
  rdfs:label "Change Driver"^^xsd:string .

<http://www.misa.org.ca/mrms#ServiceValue>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Location> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  dc11:description "Defines the expectations of parties receiving the Service's Output directly or indirectly, and ensures their alignment with associated Service Objectives and Outcomes. The way in which delivering the Service Output to the Target Groups contributes to Program and Service Outcomes."^^xsd:string ;
  rdfs:label "Service Value"^^xsd:string .

<http://www.misa.org.ca/mrms#Output>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Project> ;
  rdfs:label "Output"^^xsd:string ;
  dc11:description "A unit of value produced by a Service and conveyed to a Service Recipient."^^xsd:string ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> .

<http://www.misa.org.ca/mrms#Location>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ResourceAuthorities> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  dc11:description "A business concept that defines a location of interest to the business where processes are carried out, resources are located and parties are located"^^xsd:string ;
  rdfs:label "Location"^^xsd:string .

<http://www.misa.org.ca/mrms#ResourceAuthorities>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#ServiceAccountabilities> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#AccountabilityElement> ;
  rdfs:label "Resource Authorities"^^xsd:string ;
  dc11:description "Specifies information about the resources authorized by organization units in terms of roles and budget allocations."^^xsd:string .

<http://www.misa.org.ca/mrms#AccountabilityElement>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#AssessableElement>, skos:Concept, <http://www.misa.org.ca/mrms#LocatableElement>, foaf:Project, <http://www.misa.org.ca/mrms#TypeClassifier>, owl:Nothing, foaf:Image, <http://www.misa.org.ca/mrms#DeliverableElement>, <http://www.misa.org.ca/mrms#ImpactAssessment>, skos:ConceptScheme, <http://www.misa.org.ca/mrms#AccountableElement>, geo:SpatialThing, <http://open-services.net/ns/am#Resource>, <http://www.misa.org.ca/mrms#BudgetableItem>, foaf:Document, skos:Collection, foaf:OnlineAccount, foaf:Agent, <http://www.misa.org.ca/mrms#OutputProducer>, <http://www.misa.org.ca/mrms#ImpcatableElement> ;
  rdfs:label "Accountability Element"^^xsd:string ;
  dc11:description "An element that can be accountable for Accountable Elements"^^xsd:string ;
  rdfs:subClassOf <http://open-services.net/ns/am#Resource> .

<http://www.misa.org.ca/mrms#ServiceLevelAgreement>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#TargetGroup> ;
  rdfs:label "Service Level Agreements"^^xsd:string ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  dc11:description "Information about the relationship that one Provider / Internal Service has with zero, one or more Public and/or other Provider / Internal Services."^^xsd:string .

<http://www.misa.org.ca/mrms#Process>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#TargetGroup> ;
  rdfs:label "Process"^^xsd:string ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#ImpcatableElement>, <http://www.misa.org.ca/mrms#OutputProducer>, <http://www.misa.org.ca/mrms#DeliverableElement>, <http://www.misa.org.ca/mrms#Element>, <http://www.misa.org.ca/mrms#AccountableElement>, <http://www.misa.org.ca/mrms#AssessableElement> ;
  dc11:description "A business concept that deals with a sequence of tasks, executed by a role, using input resources to produce higher value outputs. Processes are triggered by events. Processes participate in a value chain to produce service outputs."^^xsd:string .

<http://www.misa.org.ca/mrms#Service>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#Outcome>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#PerformanceIndicator>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Process> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element>, <http://www.misa.org.ca/mrms#AccountableElement>, <http://www.misa.org.ca/mrms#LocatableElement>, <http://www.misa.org.ca/mrms#AssessableElement>, <http://www.misa.org.ca/mrms#OutputProducer>, <http://www.misa.org.ca/mrms#ImpcatableElement>, <http://www.misa.org.ca/mrms#DeliverableElement> ;
  dc11:description "A commitment to deliver Outputs that have Service Value and contribute to Outcomes."^^xsd:string ;
  rdfs:label "Service"^^xsd:string .

<http://www.misa.org.ca/mrms#PerformanceIndicator>
  a owl:Class ;
  owl:disjointWith <http://www.misa.org.ca/mrms#ProcessResponsibilities>, <http://www.misa.org.ca/mrms#ServiceValue>, <http://www.misa.org.ca/mrms#ResourceAuthorities>, <http://www.misa.org.ca/mrms#OrganizationUnit>, <http://www.misa.org.ca/mrms#Location>, <http://www.misa.org.ca/mrms#ChangeDriver>, <http://www.misa.org.ca/mrms#Need>, <http://www.misa.org.ca/mrms#Resource>, <http://www.misa.org.ca/mrms#ServiceAccountabilities>, <http://www.misa.org.ca/mrms#Program>, <http://www.misa.org.ca/mrms#Output>, <http://www.misa.org.ca/mrms#ServiceLevelAgreement>, <http://www.misa.org.ca/mrms#Service>, <http://www.misa.org.ca/mrms#Process>, <http://www.misa.org.ca/mrms#Project>, <http://www.misa.org.ca/mrms#TargetGroup>, <http://www.misa.org.ca/mrms#Outcome> ;
  rdfs:subClassOf <http://www.misa.org.ca/mrms#Element> ;
  rdfs:label "Performance Indicator"^^xsd:string ;
  dc11:description "A measure of the efficiency, effectiveness and quality of a Program, a Service, a Process, an Activity, a Task or a Resource."^^xsd:string .

<http://www.misa.org.ca/mrms#Project>
  a owl:Class ;
