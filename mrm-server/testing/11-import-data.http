###############################################################################
# 11-import-data.http — Test bulk import via PUT /oslc/{sp}/import
#
# Imports RDF data (Turtle or TriG) into a ServiceProvider.
# Run 01 and 02 first to create the catalog and a ServiceProvider.
###############################################################################

@baseUrl = http://localhost:3002

### 1. Import Turtle data with known MRM resource types
PUT {{baseUrl}}/oslc/city-of-ottawa/import
Content-Type: text/turtle

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix mrm: <http://www.misa.org.ca/mrm#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<http://localhost:3002/resources/import-svc-1>
  a mrm:Service ;
  dcterms:title "Imported Waste Collection" ;
  dcterms:description "A service imported via bulk import" .

<http://localhost:3002/resources/import-svc-2>
  a mrm:Service ;
  dcterms:title "Imported Road Maintenance" ;
  dcterms:description "Another service imported via bulk import" .

### 2. Import Turtle data with unknown resource types (should warn)
PUT {{baseUrl}}/oslc/city-of-ottawa/import
Content-Type: text/turtle

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <http://example.org/ns#> .

<http://localhost:3002/resources/unknown-type-1>
  a ex:UnknownType ;
  dcterms:title "Unknown Type Resource" .

### 3. Import TriG data (named graphs)
PUT {{baseUrl}}/oslc/city-of-ottawa/import
Content-Type: application/trig

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix mrm: <http://www.misa.org.ca/mrm#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<http://localhost:3002/resources/trig-svc-1> {
  <http://localhost:3002/resources/trig-svc-1>
    a mrm:Service ;
    dcterms:title "TriG Imported Service" ;
    dcterms:description "Imported via TriG format" .
}

### 4. Verify imported resources via query
GET {{baseUrl}}/oslc/city-of-ottawa/query/Service?oslc.prefix=dcterms%3D%3Chttp%3A%2F%2Fpurl.org%2Fdc%2Fterms%2F%3E&oslc.where=dcterms%3Atitle%3D%22Imported%20Waste%20Collection%22
Accept: text/turtle

### 5. Import empty body (should return 400)
PUT {{baseUrl}}/oslc/city-of-ottawa/import
Content-Type: text/turtle

### 6. Import invalid Turtle (should return 400)
PUT {{baseUrl}}/oslc/city-of-ottawa/import
Content-Type: text/turtle

this is not valid turtle content !!!
