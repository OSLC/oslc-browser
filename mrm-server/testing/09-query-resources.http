###############################################################################
# 09-query-resources.http — Test OSLC query capability for MRM types
#
# Run 01 through 04 first to set up test data.
#
# All query capabilities share a single queryBase URL. Clients filter
# by type via oslc.where when desired. Queries use POST with oslc.prefix
# on the URL and OSLC query parameters in the form-encoded body.
###############################################################################

@baseUrl = http://localhost:3002
@queryBase = {{baseUrl}}/oslc/city-of-ottawa/query
@prefix = oslc.prefix=dcterms%3D%3Chttp%3A%2F%2Fpurl.org%2Fdc%2Fterms%2F%3E%2Cmrm%3D%3Chttp%3A%2F%2Fwww.misa.org.ca%2Fmrm%23%3E

### 1. Query all resources (no type filter)
GET {{queryBase}}
Accept: text/turtle

### 2. Query Services with oslc.where filter
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.where=rdf:type=mrm:Service and dcterms:identifier="SVC-001"

### 3. Query with oslc.select for specific properties
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.select=dcterms:title,dcterms:description

### 4. Query all Processes (type filter via oslc.where)
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.where=rdf:type=mrm:Process

### 5. Query all OrganizationUnits (type filter via oslc.where)
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.where=rdf:type=mrm:OrganizationUnit

### 6. Query all Programs (type filter via oslc.where)
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.where=rdf:type=mrm:Program

### 7. Query with ordering
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.orderBy=+dcterms:title

### 8. Query with paging
POST {{queryBase}}?{{prefix}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.pageSize=2

### 9. Query as JSON-LD
GET {{queryBase}}
Accept: application/ld+json

### 10. Query with search terms
POST {{queryBase}}
Accept: text/turtle
Content-Type: application/x-www-form-urlencoded

oslc.searchTerms="water"
